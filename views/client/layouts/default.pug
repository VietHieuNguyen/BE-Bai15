include ../mixins/alert.pug

doctype html    
html
  head

    title #{pageTitle}
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous") 
    link(href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" rel="stylesheet" ) 
    link(rel="stylesheet", href="/css/style.css")
    //- File upload preview
    link(rel="stylesheet", href="https://unpkg.com/file-upload-with-preview/dist/style.css")
  body
    +alert-success(3000)

    include ../partials/header.pug

    block main
    
    include ../partials/footer.pug


    script(src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js" integrity="sha384-IQsoLXl5PILFhosVNubq5LC7Qb9DXgDA9i+tQ8Zj3iwWAwPtgFTxbJ8NT4GN1R8p" crossorigin="anonymous")
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.min.js" integrity="sha384-cVKIPhGWiC2Al4u+LWgxfKTRIcfu0JTxR+EQDz/bgldoEyl4H0zUF0QKbrJ0EcQF" crossorigin="anonymous")
    script(src="/js/script.js") 

    //- SocketIO 
    script(src="/socket.io/socket.io.js")

    script(src="/js/socket.js") 
    
    script(type="module" src="/js/chat.js") 


    //- emoji-picker-element 
    script(type ="module" src="https://cdn.jsdelivr.net/npm/emoji-picker-element@^1/index.js")
    //- END emoji-picker-element

    //- File upload preview
    script(src="https://unpkg.com/file-upload-with-preview/dist/index.js") 
    script(src="https://unpkg.com/file-upload-with-preview@5.0.0/dist/file-upload-with-preview.iife.js")